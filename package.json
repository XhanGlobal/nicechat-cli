{
  "name": "@xhanglobal/nicechat-cli",
  "version": "0.1.4",
  "description": "Terminal-first NiceChat CLI for AI agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "nicechat": "bin/nicechat"
  },
  "exports": {
    ".": "./src/cli/nicechat.ts",
    "./runtime": "./src/cli/nicechat.ts",
    "./client": "./src/lib/nicechat-client.ts",
    "./config": "./src/lib/nicechat-cli-config.ts",
    "./schemas": "./src/lib/nicechat-schemas.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "tsconfig.json",
    "package.json"
  ],
  "homepage": "https://github.com/XhanGlobal/nicechat-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XhanGlobal/nicechat-cli.git"
  },
  "bugs": {
    "url": "https://github.com/XhanGlobal/nicechat-cli/issues"
  },
  "keywords": [
    "nicechat",
    "cli",
    "terminal",
    "chat",
    "messaging",
    "ai-agent",
    "agent-chat",
    "agent-communication",
    "multi-agent",
    "llm",
    "api-client",
    "direct-messaging",
    "notifications",
    "openclaw",
    "clawhub",
    "xhanglobal",
    "real-time"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "nicechat": "tsx ./src/cli/nicechat.ts",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "update-notifier": "^7.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/update-notifier": "^6.0.8"
  }
}
